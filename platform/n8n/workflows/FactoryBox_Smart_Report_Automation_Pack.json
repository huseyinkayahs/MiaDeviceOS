{
  "name": "FactoryBox - Smart Report Automation Pack",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 5 18 * * *"
            }
          ]
        }
      },
      "id": "schedule-site-daily-report",
      "name": "Daily 18:05",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://host.docker.internal:3100/api/sites/site01/ai/daily-report/telegram?save=1",
        "options": {}
      },
      "id": "get-site-daily-telegram-report",
      "name": "Get Site Daily Telegram Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "={{$json.telegram_text}}",
        "additionalFields": {}
      },
      "id": "send-site-telegram-report",
      "name": "Send Site Telegram Report",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        780,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "",
          "name": "FactoryBox Telegram Bot"
        }
      }
    }
  ],
  "connections": {
    "Daily 18:05": {
      "main": [
        [
          {
            "node": "Get Site Daily Telegram Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Site Daily Telegram Report": {
      "main": [
        [
          {
            "node": "Send Site Telegram Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
