
# FactoryBox v4.6 SaaS Foundation Pack

# İlk kurulumda false kalabilir.
# true yapınca /api endpointleri login ister.
AUTH_ENABLED=false

# Login açık olursa kullanılacak admin kullanıcı.
FACTORYBOX_ADMIN_EMAIL=admin@factorybox.local
FACTORYBOX_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
FACTORYBOX_ADMIN_ROLE=owner

# Session süresi
AUTH_SESSION_HOURS=12

# v5.3 Password Reset / Account Recovery
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60

# E-postadaki linkin dışarıdan erişilen temel adresi.
# Lokal test:
PUBLIC_APP_URL=http://localhost:3100
# Production örneği:
# PUBLIC_APP_URL=https://panel.firmaniz.com



# v5.5 Subscription Enforcement / Usage Limit Guard
# true: expired/cancelled/past_due tenant operasyon API'leri engellenir.
# false: yalnızca izleme yapılır, API engeli uygulanmaz.
SUBSCRIPTION_ENFORCEMENT_ENABLED=true
