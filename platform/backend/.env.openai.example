
# FactoryBox v4.4 OpenAI SmartAI Upgrade

# OpenAI API key sunucuda tutulmalı, tarayıcıya koyulmaz.
OPENAI_API_KEY=

# Varsayılan model. İstersen değiştirebilirsin.
OPENAI_MODEL=gpt-5-mini

# false yaparsan API key olsa bile OpenAI çağrısı yapılmaz, rule fallback çalışır.
SMARTAI_OPENAI_ENABLED=true
