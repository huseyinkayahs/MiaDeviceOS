
# FactoryBox v4.5 Email Report Delivery

# false yaparsan mail gönderimi kapalı kalır.
EMAIL_REPORTS_ENABLED=true

# SMTP örnekleri:
# Gmail için uygulama şifresi gerekir:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
#
# Yandex/kurumsal mail için sağlayıcının SMTP bilgilerini kullan.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Dashboard'da alıcı boş bırakılırsa bu adrese gönderilir.
REPORT_EMAIL_TO=
