# SmartDashboard Lite settings
PORT=3000

# MQTT broker
MQTT_URL=mqtt://broker.emqx.io:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# FactoryBox / MiaDeviceOS device topics
MQTT_BASE_TOPIC=mia/site01/laser01
DEVICE_ID=laser01

# Device is considered online if a heartbeat, command status, or machine status
# was received in the last N seconds.
DEVICE_ONLINE_TIMEOUT_SEC=90
